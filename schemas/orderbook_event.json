{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OrderBookEvent",
  "type": "object",
  "additionalProperties": false,
  "required": ["exchange", "pair", "side", "event_time", "levels"],
  "properties": {
    "exchange": {
      "type": "string"
    },
    "pair": {
      "type": "string"
    },
    "side": {
      "type": "string",
      "enum": ["asks", "bids"]
    },
    "event_time": {
      "type": "integer",
      "description": "Timestamp in milliseconds UTC"
    },
    "levels": {
      "type": "array",
      "items": {
        "title": "PriceLevel",
        "type": "object",
        "additionalProperties": false,
        "required": ["price", "quantity"],
        "properties": {
          "price": {
            "type": "string"
          },
          "quantity": {
            "type": "string"
          }
        }
      }
    }
  }
}
